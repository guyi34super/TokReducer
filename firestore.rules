rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Users can read their own profile but CANNOT write to it.
      // All user doc mutations (tier, requests_used, stripe_*, agreement,
      // daily_requests) go through the backend Admin SDK which bypasses rules.
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      // Per-user config subcollection -- read-only from client.
      // Writes go through POST /api/config (Admin SDK).
      match /config/{docId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      // Per-user request logs -- read-only from client.
      // Writes go through the backend after each proxy request.
      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      // Per-user audit logs -- read-only from client.
      // Writes go through the backend Admin SDK.
      match /audit_logs/{logId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
