# Firebase Admin SDK credentials (use one of the two)
# Option A: file path (local / Docker secret mount)
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json
# Option B: raw JSON string (e.g. from a secrets manager injecting env)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Stripe (for Pro plan payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Frontend URL (for Stripe redirect)
FRONTEND_URL=http://localhost:3000

# Rust compressor (optional; when set, Python uses Rust for compression)
# In Docker: http://rust-compressor:8081
# Local dev: http://localhost:8081
RUST_COMPRESSOR_URL=
